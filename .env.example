# PostgreSQL. Local: same value for both. Supabase prod: pooled vs direct (see docs/DEPLOY.md).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/koi_pos?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/koi_pos?schema=public"
# >=32 random chars, UNIQUE per environment. Never reuse this value. Generate with:
#   openssl rand -base64 36
SESSION_SECRET="change-me-generate-with-openssl-rand-base64-36"
