generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Supabase pgbouncer, :6543) for the app
  directUrl = env("DIRECT_URL") // direct (:5432) for prisma migrate deploy
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  PENDING
  PREPARING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum InventoryMovementType {
  PURCHASE
  WASTE
  ADJUSTMENT
  SALE
}

enum ExpenseCategory {
  LOCAL
  PERSONAL
  SERVICIOS
  INSUMOS_EXTRA
  MARKETING
  EQUIPO
  IMPUESTOS
  OTROS
}

enum ExpenseFrequency {
  MONTHLY
  BIWEEKLY
  WEEKLY
}

model Branch {
  id                 String              @id @default(cuid())
  name               String
  code               String              @unique
  address            String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              UserBranch[]
  cashSessions       CashSession[]
  inventory          BranchInventory[]
  inventoryMovements InventoryMovement[]
  orders             Order[]
  expenses           Expense[]
  recurringExpenses  RecurringExpense[]
  emailLogs          EmailLog[]
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(OPERATOR)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  branches           UserBranch[]
  openedCashSessions CashSession[]       @relation("OpenedCashSessions")
  closedCashSessions CashSession[]       @relation("ClosedCashSessions")
  createdOrders      Order[]
  inventoryMovements InventoryMovement[]
  expenses           Expense[]
}

model UserBranch {
  id       String @id @default(cuid())
  userId   String
  branchId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
}

model CashSession {
  id                 String            @id @default(cuid())
  branchId           String
  openedById         String
  closedById         String?
  openingAmount      Decimal           @db.Decimal(12, 2)
  closingAmount      Decimal?          @db.Decimal(12, 2)
  expectedCashAmount Decimal?          @db.Decimal(12, 2)
  cashDifference     Decimal?          @db.Decimal(12, 2)
  status             CashSessionStatus @default(OPEN)
  openedAt           DateTime          @default(now())
  closedAt           DateTime?
  notes              String?
  branch             Branch            @relation(fields: [branchId], references: [id])
  openedBy           User              @relation("OpenedCashSessions", fields: [openedById], references: [id])
  closedBy           User?             @relation("ClosedCashSessions", fields: [closedById], references: [id])
  orders             Order[]

  @@index([branchId, status])
  @@index([openedById])
}

model Product {
  id             String          @id @default(cuid())
  name           String
  description    String?
  basePrice      Decimal         @db.Decimal(12, 2)
  imageUrl       String?
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  modifierGroups ModifierGroup[]
  recipeItems    RecipeItem[]
  orderItems     OrderItem[]
}

model ModifierGroup {
  id            String     @id @default(cuid())
  productId     String
  name          String
  isRequired    Boolean    @default(false)
  minSelections Int        @default(0)
  maxSelections Int        @default(1)
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifiers     Modifier[]

  @@index([productId])
}

model Modifier {
  id              String              @id @default(cuid())
  modifierGroupId String
  name            String
  priceDelta      Decimal             @db.Decimal(12, 2)
  sortOrder       Int                 @default(0)
  isActive        Boolean             @default(true)
  modifierGroup   ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  recipeItems     RecipeItem[]
  orderModifiers  OrderItemModifier[]

  @@index([modifierGroupId])
}

model Ingredient {
  id                 String              @id @default(cuid())
  name               String
  unit               String
  costPerUnit        Decimal             @default(0) @db.Decimal(12, 4)
  lowStockThreshold  Decimal             @default(0) @db.Decimal(12, 3)
  isActive           Boolean             @default(true)
  supplier           String?
  packQuantity       Decimal?            @db.Decimal(12, 3) // qty in `unit` per purchase pack
  packPrice          Decimal?            @db.Decimal(12, 2) // price paid for that pack
  recipeItems        RecipeItem[]
  branchInventory    BranchInventory[]
  inventoryMovements InventoryMovement[]
}

model RecipeItem {
  id           String     @id @default(cuid())
  productId    String?
  modifierId   String?
  ingredientId String
  quantity     Decimal    @db.Decimal(12, 3)
  product      Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifier     Modifier?  @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([productId])
  @@index([modifierId])
  @@index([ingredientId])
}

model BranchInventory {
  id             String     @id @default(cuid())
  branchId       String
  ingredientId   String
  quantityOnHand Decimal    @default(0) @db.Decimal(12, 3)
  updatedAt      DateTime   @updatedAt
  branch         Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([branchId, ingredientId])
  @@index([ingredientId])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  branchId      String
  ingredientId  String
  type          InventoryMovementType
  quantityDelta Decimal               @db.Decimal(12, 3)
  reason        String
  orderId       String?
  createdById   String
  createdAt     DateTime              @default(now())
  branch        Branch                @relation(fields: [branchId], references: [id])
  ingredient    Ingredient            @relation(fields: [ingredientId], references: [id])
  order         Order?                @relation(fields: [orderId], references: [id])
  createdBy     User                  @relation(fields: [createdById], references: [id])

  @@index([branchId, createdAt])
  @@index([ingredientId])
  @@index([orderId])
}

model Customer {
  id        String   @id @default(cuid())
  nit       String   @unique
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id               String              @id @default(cuid())
  branchId         String
  cashSessionId    String
  customerId       String?
  customerNit      String              @default("CF")
  customerName     String              @default("Consumidor Final")
  customerPhone    String?
  status           OrderStatus         @default(PENDING)
  subtotal         Decimal             @db.Decimal(12, 2)
  discountTotal    Decimal             @default(0) @db.Decimal(12, 2)
  taxTotal         Decimal             @default(0) @db.Decimal(12, 2)
  total            Decimal             @db.Decimal(12, 2)
  costOfGoodsTotal Decimal             @default(0) @db.Decimal(12, 2)
  grossProfit      Decimal             @default(0) @db.Decimal(12, 2)
  felUuid          String?
  felDteNumber     String?
  felCertifiedAt   DateTime?
  createdById      String
  paidAt           DateTime            @default(now())
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime            @default(now())
  branch           Branch              @relation(fields: [branchId], references: [id])
  cashSession      CashSession         @relation(fields: [cashSessionId], references: [id])
  customer         Customer?           @relation(fields: [customerId], references: [id])
  createdBy        User                @relation(fields: [createdById], references: [id])
  items            OrderItem[]
  payments         Payment[]
  inventoryMoves   InventoryMovement[]

  @@index([branchId, createdAt])
  @@index([cashSessionId])
  @@index([status])
}

model OrderItem {
  id                  String              @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  basePriceSnapshot   Decimal             @db.Decimal(12, 2)
  quantity            Int
  lineTotal           Decimal             @db.Decimal(12, 2)
  unitCostSnapshot    Decimal             @default(0) @db.Decimal(12, 4)
  lineCostSnapshot    Decimal             @default(0) @db.Decimal(12, 4)
  notes               String?
  order               Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product             @relation(fields: [productId], references: [id])
  modifiers           OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemModifier {
  id                   String    @id @default(cuid())
  orderItemId          String
  modifierId           String
  modifierNameSnapshot String
  priceDeltaSnapshot   Decimal   @db.Decimal(12, 2)
  orderItem            OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier             Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
  @@index([modifierId])
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  receivedAmount Decimal?      @db.Decimal(12, 2)
  changeAmount   Decimal?      @db.Decimal(12, 2)
  reference      String?
  createdAt      DateTime      @default(now())
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([method])
}

model AppSettings {
  id                  String   @id @default("global")
  companyName         String   @default("Koi POS")
  accentColor         String   @default("#ff9766")
  sidebarColor        String   @default("#ffffff")
  backgroundColor     String   @default("#ffe2d2")
  logoUrl             String?
  currencySymbol      String   @default("Q")
  modifierGridEnabled Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model Expense {
  id            String            @id @default(cuid())
  branchId      String?
  category      ExpenseCategory
  description   String
  amount        Decimal           @db.Decimal(12, 2)
  incurredOn    DateTime
  paymentMethod PaymentMethod?
  vendor        String?
  recurringId   String?
  notes         String?
  createdById   String
  createdAt     DateTime          @default(now())
  branch        Branch?           @relation(fields: [branchId], references: [id])
  recurring     RecurringExpense? @relation(fields: [recurringId], references: [id])
  createdBy     User              @relation(fields: [createdById], references: [id])

  @@index([branchId, incurredOn])
  @@index([category])
  @@index([recurringId])
}

model RecurringExpense {
  id          String           @id @default(cuid())
  branchId    String?
  category    ExpenseCategory
  description String
  amount      Decimal          @db.Decimal(12, 2)
  frequency   ExpenseFrequency
  dayOfPeriod Int
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  branch      Branch?          @relation(fields: [branchId], references: [id])
  expenses    Expense[]

  @@index([branchId])
  @@index([active])
}

model EmailLog {
  id       String   @id @default(cuid())
  branchId String
  forDate  DateTime @db.Date
  kind     String
  sentTo   String
  sentAt   DateTime @default(now())
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@unique([branchId, forDate, kind])
  @@index([branchId, forDate])
}
